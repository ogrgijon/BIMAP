# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ── Virtual environment ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Test / coverage ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.lcov

# ── Editor & IDE ──────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ── PyInstaller ───────────────────────────────────────────────────────────────
installer/dist/
installer/build/
*.spec.bak
# Portable release artifact produced locally by build_installer.ps1
BIMAP-v*-windows-x64-portable.exe

# ── BIMAP runtime files ───────────────────────────────────────────────────────
# Tile cache (diskcache creates a directory)
tile_cache/
*.db
*.db-shm
*.db-wal

# Auto-save and backup files
*.bimap.bak
autosave_*.bimap

# Exported PDFs generated during development
*.pdf

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Secrets / credentials ─────────────────────────────────────────────────────
.env
.env.*
*.env.local
secrets.json
credentials.json
token.json
*.key
*.pem
*.p12
*.pfx
# Never commit connection strings or API keys
connection_strings.*
api_keys.*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
